{
  "name": "data-insights-by-ray-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Data Insights by Ray multi-tenant tutoring and analytics platform",
  "scripts": {
    "serve": "npx http-server . -p 4173 -c-1",
    "test": "node --import ./tests/setup.mjs --test tests/*.test.mjs",
    "stress:test": "node --import ./tests/setup.mjs ./tests/stress-runner.mjs",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "dexie": "^4.2.1",
    "fake-indexeddb": "^6.2.4"
  }
}
