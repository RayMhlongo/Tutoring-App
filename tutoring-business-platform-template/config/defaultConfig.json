{
  "business": {
    "name": "Tutoring Business",
    "logoPath": "./assets/default-logo/default-logo.svg",
    "colors": {
      "primary": "#0e3a67",
      "secondary": "#8ec6eb",
      "accent": "#f4c44a"
    }
  },
  "subjects": ["Maths", "English"],
  "grades": ["Grade 8", "Grade 9", "Grade 10", "Grade 11", "Grade 12"],
  "studentFields": [
    { "key": "firstName", "label": "First Name", "type": "text", "required": true },
    { "key": "surname", "label": "Surname", "type": "text", "required": true },
    { "key": "grade", "label": "Grade", "type": "text", "required": true },
    { "key": "parentPhone", "label": "Parent Phone", "type": "text", "required": false },
    { "key": "parentEmail", "label": "Parent Email", "type": "text", "required": false }
  ],
  "lessonStructure": {
    "categories": ["Revision", "Exam Prep", "Homework Support"],
    "fields": [
      { "key": "notes", "label": "Lesson Notes", "type": "textarea" },
      { "key": "homework", "label": "Homework", "type": "textarea" },
      { "key": "progress", "label": "Progress", "type": "textarea" }
    ]
  },
  "parentCommunication": {
    "template": "Today {student} worked on {subject}. Homework: {homework}."
  },
  "setupCompleted": false,
  "templateMode": true
}
